{
  "name": "startupfiles",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @startupfiles/web dev",
    "dev:backend": "convex dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "convex:codegen": "convex codegen"
  },
  "devDependencies": {
    "@convex-dev/auth": "^0.0.86",
    "concurrently": "^9.2.1",
    "convex": "^1.25.4",
    "resend": "^4.0.1",
    "turbo": "^2.0.14"
  }
}
